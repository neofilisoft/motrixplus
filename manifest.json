{
  "manifest_version": 3,
  "name": "Motrix+",
  "version": "1.0.0",
  "description": "Smart download manager with stable bandwidth and latency optimization. Fork of Motrix — rebranded as Motrix Plus.",
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Motrix+",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "permissions": [
    "downloads",
    "downloads.open",
    "storage",
    "notifications",
    "tabs",
    "contextMenus",
    "webRequest",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+M",
        "mac": "Alt+M"
      },
      "description": "Open Motrix+"
    }
  }
}
